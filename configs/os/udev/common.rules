# Here are described some bindings for PiKVM devices.
# Do not edit this file.

ACTION!="remove", KERNEL=="ttyACM[0-9]*", SUBSYSTEM=="tty", SUBSYSTEMS=="usb", \
	ATTRS{idVendor}=="1209", ATTRS{idProduct}=="eda3", SYMLINK+="kvmd-hid-bridge"

ACTION!="remove", KERNEL=="ttyACM[0-9]*", SUBSYSTEM=="tty", SUBSYSTEMS=="usb", \
	ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="1080", SYMLINK+="kvmd-switch"

ACTION=="add", SUBSYSTEM=="usb", \
	ATTR{idVendor}=="2e8a", ATTR{idProduct}=="0003|000f", \
	PROGRAM="/usr/bin/systemd-escape -p --template=kvmd-flash-pico@.service %s{busnum}/%s{devnum}", \
	ENV{SYSTEMD_WANTS}+="%c", TAG+="systemd"

ACTION!="remove", KERNEL=="nbd15", SUBSYSTEM=="block", \
	GROUP="kvmd-nbd", \
	SYMLINK+="kvmd-nbd", \
	RUN+="/usr/bin/chgrp kvmd-nbd %S%p/disconnect", \
	RUN+="/usr/bin/chmod g+w %S%p/disconnect"

SUBSYSTEM=="video4linux", ACTION=="add", KERNEL=="video[0-9*]", \
	SUBSYSTEMS=="gadget", DRIVERS=="configfs-gadget.kvmd", ATTR{function_name}=="uvc.usb0", \
	SYMLINK+="kvmd-camera", \
	PROGRAM="/usr/bin/systemd-escape -p --template=kvmd-camera@.service $env{DEVNAME}", \
	ENV{SYSTEMD_WANTS}+="%c", TAG+="systemd"

# Disable USB autosuspend for critical devices
ACTION!="remove", SUBSYSTEM=="usb", ATTR{idVendor}=="1209", ATTR{idProduct}=="eda3", GOTO="kvmd-usb"
ACTION!="remove", SUBSYSTEM=="usb", ATTR{idVendor}=="2e8a", ATTR{idProduct}=="1080", GOTO="kvmd-usb"
GOTO="end"

LABEL="kvmd-usb"
ATTR{power/control}="on", ATTR{power/autosuspend_delay_ms}="-1"

LABEL="end"
